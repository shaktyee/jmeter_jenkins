          <stringProp name="script">import org.apache.kafka.clients.producer.ProducerConfig;
import org.apache.kafka.clients.producer.KafkaProducer;
import org.apache.kafka.clients.producer.ProducerRecord;
import java.util.Properties;

Properties props1 = new Properties();
props1.put(ProducerConfig.BOOTSTRAP_SERVERS_CONFIG, &quot;${kafka_bootstrap_server}:9092&quot;);
props1.put(ProducerConfig.KEY_SERIALIZER_CLASS_CONFIG, org.apache.kafka.common.serialization.StringSerializer.class);
props1.put(ProducerConfig.VALUE_SERIALIZER_CLASS_CONFIG, io.confluent.kafka.serializers.KafkaAvroSerializer.class);

props1.put(&quot;schema.registry.url&quot;, &quot;${kafka_schema_registry}&quot;);
props1.put(&quot;auto.register.schemas&quot;, &quot;false&quot;);
props1.put(&quot;basic.auth.credentials.source&quot;,&quot;USER_INFO&quot;);
props1.put(&quot;basic.auth.user.info&quot;,&quot;HSUQ7IVOVKNJPNTR:lgRm/DRyechi0bZhj10eFPqb8Y3kMyDVs2infYrsMB8Y0L/bgbsOA4izJosNzhMc&quot;);
props1.put(&quot;sasl.mechanism&quot;, &quot;PLAIN&quot;);
props1.put(&quot;security.protocol&quot;, &quot;SASL_SSL&quot;);
props1.put(&quot;sasl.jaas.config&quot;,&quot;org.apache.kafka.common.security.plain.PlainLoginModule required username=&apos;QC3B5BJNY6FGUSCV&apos; password=&apos;TYzOksMewp7SVP5XbKIW+hGJiscKuVSWPJEqfxCnpq2ZkKpAJlIPjsaAFHtY8CFA&apos;;&quot;);
KafkaProducer producer = new KafkaProducer(props1);

props.put(&quot;producer&quot;, producer);
</stringProp>
