//props1.put(&quot;basic.auth.user.info&quot;, &quot;EL52U6TMZYO4L3RZ:cG8hgQrskkQCnhzn9bNi+mFxy/l/roe9tw3xysxZkuMmuLyGc8SMxa+GkL1lPVLP&quot;);  //perf
