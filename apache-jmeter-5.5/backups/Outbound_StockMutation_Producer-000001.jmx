          <stringProp name="script">System.setProperty(&quot;java.security.auth.login.config&quot; ,&quot;C:/WorkStation/RFIDC/Scripts/Inbound Kafka  Scripts/prf_Kafka_Jaas_NonPIITopic.conf&quot;);

import org.apache.kafka.clients.producer.ProducerConfig;
