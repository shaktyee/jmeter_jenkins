        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Send Record - JSR223 Sampler" enabled="true">
          <stringProp name="cacheKey">false</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import org.apache.kafka.clients.producer.ProducerConfig;
import org.apache.kafka.clients.producer.KafkaProducer;
import org.apache.kafka.clients.producer.ProducerRecord;
import java.util.Properties;
import org.json.JSONObject;

import org.apache.avro.Schema;
import org.apache.avro.generic.GenericData;
import org.apache.avro.generic.GenericRecord;
import org.apache.kafka.clients.producer.KafkaProducer;
import org.apache.kafka.clients.producer.ProducerConfig;
import org.apache.kafka.clients.producer.ProducerRecord;
import org.apache.kafka.common.serialization.StringSerializer;
import io.confluent.kafka.serializers.KafkaAvroSerializer;

KafkaProducer producer = props.get(&quot;producer&quot;);
String key= &quot;1000009@urn:epc:id:sgtin:2000035.058644.11010535215&quot;;
String userSchema=&quot;{\&quot;type\&quot;: \&quot;record\&quot;, \&quot;name\&quot;: \&quot;RealtimeStockMutation\&quot;, \&quot;namespace\&quot;: \&quot;com.nedap.retail.idcloud\&quot;, \&quot;fields\&quot;: [{\&quot;name\&quot;: \&quot;time\&quot;, \&quot;type\&quot;: \&quot;string\&quot;, \&quot;doc\&quot;: \&quot;ISO8601 date/time indicating when the event took place that caused this mutation\&quot;},{ \&quot;name\&quot;: \&quot;epc\&quot;, \&quot;type\&quot;: \&quot;string\&quot;, \&quot;doc\&quot;: \&quot;EPC in GS1 EPC pure identity format\&quot;}, {\&quot;name\&quot;: \&quot;gtin\&quot;, \&quot;type\&quot;: \&quot;string\&quot;, \&quot;doc\&quot;: \&quot;GTIN (numeric, 14 digits)\&quot;},{\&quot;name\&quot;: \&quot;skuCode\&quot;, \&quot;type\&quot;: [\&quot;null\&quot;, \&quot;string\&quot;], \&quot;doc\&quot;: \&quot;May contain null if SKU code could not be determined from GTIN\&quot;}, {\&quot;name\&quot;: \&quot;serial\&quot;, \&quot;type\&quot;: \&quot;string\&quot;, \&quot;doc\&quot;: \&quot;Serial part of the EPC (can be alfanumeric and case sensitive when using 198 bit labels)\&quot;},{\&quot;name\&quot;: \&quot;mutationType\&quot;, \&quot;type\&quot;: {\&quot;type\&quot;: \&quot;enum\&quot;, \&quot;name\&quot;: \&quot;MutationTypeEnum\&quot;, \&quot;symbols\&quot;: [\&quot;add\&quot;, \&quot;update\&quot;, \&quot;delete\&quot;]}, \&quot;doc\&quot;: \&quot;Indicates if this EPC is added to, updated in or deleted from the realtime stock database. Deletes are only triggered by automatic cleanups.\&quot;}, {\&quot;name\&quot;: \&quot;bizStep\&quot;, \&quot;type\&quot;: \&quot;string\&quot;, \&quot;doc\&quot;: \&quot;Business step (empty string when mutationType is delete)\&quot;}, {\&quot;name\&quot;: \&quot;fromLocation\&quot;, \&quot;type\&quot;: [\&quot;null\&quot;, \&quot;string\&quot;], \&quot;doc\&quot;: \&quot;GS1 location identifier of original location (null when mutationType is add)\&quot;}, {\&quot;name\&quot;: \&quot;fromDisposition\&quot;, \&quot;type\&quot;: [\&quot;null\&quot;, \&quot;string\&quot;], \&quot;doc\&quot;: \&quot;Original disposition (null when mutationType is add)\&quot;}, {\&quot;name\&quot;: \&quot;toLocation\&quot;, \&quot;type\&quot;: [\&quot;null\&quot;, \&quot;string\&quot;], \&quot;doc\&quot;: \&quot;GS1 location identifier of new location (null when mutationType is delete)\&quot;}, {\&quot;name\&quot;: \&quot;toDisposition\&quot;, \&quot;type\&quot;: [\&quot;null\&quot;, \&quot;string\&quot;], \&quot;doc\&quot;: \&quot;New disposition (null when mutationType is delete)\&quot;}]}&quot;;

Schema.Parser parser = new Schema.Parser();
Schema schema = parser.parse(userSchema);
GenericRecord avroRecord = new GenericData.Record(schema);
avroRecord.put(&quot;time&quot;, &quot;2022-03-04T07:30:29.607Z&quot;);
avroRecord.put(&quot;epc&quot;, &quot;urn:epc:id:sgtin:2001322.075162.11000008949&quot;);
avroRecord.put(&quot;gtin&quot;, &quot;02000035586449&quot;);
avroRecord.put(&quot;skuCode&quot;, &quot;3558649&quot;);
avroRecord.put(&quot;serial&quot;, &quot;11010535219&quot;);
avroRecord.put(&quot;mutationType&quot;, new GenericData.EnumSymbol(schema.getField(&quot;mutationType&quot;).schema(), &quot;update&quot;));
avroRecord.put(&quot;bizStep&quot;, &quot;urn:epcglobal:cbv:bizstep:other&quot;);
avroRecord.put(&quot;fromLocation&quot;, &quot;http://nedapretail.us/loc/sublocation-4007022&quot;);
avroRecord.put(&quot;fromDisposition&quot;, &quot;urn:epcglobal:cbv:disp:sellable_accessible&quot;);
avroRecord.put(&quot;toLocation&quot;, &quot;http://nedapretail.us/loc/sublocation-4007022&quot;);
avroRecord.put(&quot;toDisposition&quot;, &quot;urn:epcglobal:cbv:disp:unknown&quot;);

ProducerRecord&lt;Object, Object&gt; record = new ProducerRecord&lt;&gt;(&quot;${kafka_topic_producer}&quot;, key, avroRecord);
producer.send(record);</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223Sampler>
