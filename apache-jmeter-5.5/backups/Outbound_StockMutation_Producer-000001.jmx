          <stringProp name="script">import org.apache.kafka.clients.producer.ProducerConfig;
import org.apache.kafka.clients.producer.KafkaProducer;
import org.apache.kafka.clients.producer.ProducerRecord;
import java.util.Properties;
import org.json.JSONObject;

KafkaProducer producer = props.get(&quot;producer&quot;);
String jsonMessage =&quot;${Value}&quot;
String messageKey = &quot;${Key}&quot;; //key - Node_Item
JSONObject jsonObject = new JSONObject(jsonMessage);
String posLogXMLStr = jsonObject.get(&quot;POSLOG_DATA&quot;).toString();
log.info(&quot;posLogXMLStr:&quot; + posLogXMLStr);
log.info(&quot;rawData:&quot; + jsonObject.toString());	
ProducerRecord&lt;Object, Object&gt; record = new ProducerRecord&lt;&gt;(&quot;${kafka_topic_producer}&quot;, messageKey, jsonMessage);
producer.send(record);
</stringProp>
