avroRecord.put(&quot;class_id&quot;,100120305514)
avroRecord.put(&quot;class_name&quot;,&quot;Mens&quot;)
avroRecord.put(&quot;class_num&quot;,514)	
avroRecord.put(&quot;subclass_id&quot;,100120305514730)	
