      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Produce Kafka" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
          <stringProp name="script">import org.apache.kafka.clients.producer.Producer;
import org.apache.kafka.clients.producer.KafkaProducer;
import org.apache.kafka.clients.producer.ProducerRecord;

String brokers = vars.get(&quot;KAFKA_BROKERS&quot;);
String topic = vars.get(&quot;KAFKA_TOPIC&quot;);
String user = String.valueOf(ctx.getThreadNum() + 1);
Object msg = vars.get(&quot;MESSAGE&quot;);

Properties kafkaProps = new Properties();

kafkaProps.put(&quot;bootstrap.servers&quot;, brokers);
kafkaProps.put(&quot;schema.registry.url&quot;,&quot;https://psrc-q25x7.us-east-2.aws.confluent.cloud&quot;);
kafkaProps.put(&quot;auto.register.schemas&quot;,&quot;false&quot;);
kafkaProps.put(&quot;basic.auth.credentials.source&quot;,&quot;USER_INFO&quot;);
kafkaProps.put(&quot;basic.auth.user.info&quot;,&quot;HSUQ7IVOVKNJPNTR:lgRm/DRyechi0bZhj10eFPqb8Y3kMyDVs2infYrsMB8Y0L/bgbsOA4izJosNzhMc&quot;);
kafkaProps.put(&quot;security.protocol&quot;,&quot;SASL_SSL&quot;);
kafkaProps.put(&quot;sasl.mechanism&quot;,&quot;PLAIN&quot;);
kafkaProps.put(&quot;key.serializer&quot;,&quot;org.apache.kafka.common.serialization.StringSerializer&quot;);
kafkaProps.put(&quot;value.serializer&quot;,&quot;io.confluent.kafka.serializers.KafkaAvroSerializer&quot;);
kafkaProps.put(&quot;sasl.jaas.config&quot;,&quot;org.apache.kafka.common.security.plain.PlainLoginModule required username=&apos;QC3B5BJNY6FGUSCV&apos; password=&apos;TYzOksMewp7SVP5XbKIW+hGJiscKuVSWPJEqfxCnpq2ZkKpAJlIPjsaAFHtY8CFA&apos;;&quot;);

KafkaProducer producer = new KafkaProducer(kafkaProps);

props.put(&quot;producer&quot;, producer);</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>
