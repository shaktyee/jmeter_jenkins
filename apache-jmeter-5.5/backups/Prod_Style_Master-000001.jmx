avroRecord.put(&quot;style_bucket&quot;,&quot;&quot;)	
avroRecord.put(&quot;support&quot;,&quot;&quot;)	
avroRecord.put(&quot;swim_activity&quot;,&quot;&quot;)	
avroRecord.put(&quot;taxonomy&quot;,&quot;100.120.305.514.730&quot;)	
avroRecord.put(&quot;waistband&quot;,&quot;Flat&quot;)	
avroRecord.put(&quot;weight&quot;,&quot;&quot;)	
