          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import org.apache.kafka.clients.producer.ProducerConfig;
import org.apache.kafka.clients.producer.KafkaProducer;
import org.apache.kafka.clients.producer.ProducerRecord;
import java.util.Properties;
import org.json.JSONObject;

KafkaProduecr producer = props.get(&quot;producer&quot;);

JSONObject.jsonObject = new JSONObject();
jsonObject.put(&quot;dummy&quot;,1);

log.info(&quot;JsonDat:&quot; + jsonObject.toString());

ProducerRecord&lt;Object, String&gt; record = new ProducerRecord&lt;&gt;(&quot;${kafka_topic_producer}&quot;,jsonObject.toString());
producer.send(record);
producer.close();
</stringProp>
        </JSR223Sampler>
