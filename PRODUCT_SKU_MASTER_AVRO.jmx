        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Send Record - PRODUCT_SKU_MASTER" enabled="true">
          <stringProp name="cacheKey">false</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import org.apache.avro.Schema;
import org.apache.avro.generic.GenericData;
import org.apache.avro.generic.GenericRecord;
import org.apache.kafka.clients.producer.ProducerConfig;
import org.apache.kafka.clients.producer.KafkaProducer;
import org.apache.kafka.clients.producer.ProducerRecord;
import java.util.Properties;
import org.apache.kafka.common.serialization.StringSerializer;
import io.confluent.kafka.serializers.KafkaAvroSerializer;

KafkaProducer producer = props.get(&quot;producer&quot;);

String skuSchema = &quot;${product_sku_master_avro_schema}&quot;;
Schema.Parser parser = new Schema.Parser();
Schema schema = parser.parse(skuSchema);

GenericRecord avroRecord = new GenericData.Record(schema);

avroRecord.put(&quot;sku_id&quot;,&quot;PERFTEST_${__Random(1,99999,rnd)}&quot;)
if(vars.get(&quot;skuname&quot;)!=&quot;&quot;){	avroRecord.put(&quot;sku_name&quot;,&quot;${skuname}&quot;)	}
if(vars.get(&quot;styleoptionid&quot;)!=&quot;&quot;){	avroRecord.put(&quot;style_option_id&quot;,&quot;${styleoptionid}&quot;)	}
if(vars.get(&quot;styleid&quot;)!=&quot;&quot;){	avroRecord.put(&quot;style_id&quot;,&quot;${styleid}&quot;)	}
if(vars.get(&quot;brandid&quot;)!=&quot;&quot;){	avroRecord.put(&quot;brand_id&quot;,${brandid})	}
if(vars.get(&quot;brandnum&quot;)!=&quot;&quot;){	avroRecord.put(&quot;brand_num&quot;,${brandnum})	}
if(vars.get(&quot;brandname&quot;)!=&quot;&quot;){	avroRecord.put(&quot;brand_name&quot;,&quot;${brandname}&quot;)	}
if(vars.get(&quot;divisionid&quot;)!=&quot;&quot;){	avroRecord.put(&quot;division_id&quot;,${divisionid})	}
if(vars.get(&quot;divisionnum&quot;)!=&quot;&quot;){	avroRecord.put(&quot;division_num&quot;,${divisionnum})	}
if(vars.get(&quot;divisionname&quot;)!=&quot;&quot;){	avroRecord.put(&quot;division_name&quot;,&quot;${divisionname}&quot;)	}
if(vars.get(&quot;departmentid&quot;)!=&quot;&quot;){	avroRecord.put(&quot;department_id&quot;,${departmentid})	}
if(vars.get(&quot;departmentnum&quot;)!=&quot;&quot;){	avroRecord.put(&quot;department_num&quot;,${departmentnum})	}
if(vars.get(&quot;departmentname&quot;)!=&quot;&quot;){	avroRecord.put(&quot;department_name&quot;,&quot;${departmentname}&quot;)	}
if(vars.get(&quot;classid&quot;)!=&quot;&quot;){	avroRecord.put(&quot;class_id&quot;,${classid})	}
if(vars.get(&quot;classname&quot;)!=&quot;&quot;){	avroRecord.put(&quot;class_name&quot;,&quot;${classname}&quot;)	}
if(vars.get(&quot;classnum&quot;)!=&quot;&quot;){	avroRecord.put(&quot;class_num&quot;,${classnum})	}
if(vars.get(&quot;subclassid&quot;)!=&quot;&quot;){	avroRecord.put(&quot;subclass_id&quot;,${subclassid})	}
if(vars.get(&quot;subclassnum&quot;)!=&quot;&quot;){	avroRecord.put(&quot;subclass_num&quot;,${subclassnum})	}
if(vars.get(&quot;subclassname&quot;)!=&quot;&quot;){	avroRecord.put(&quot;subclass_name&quot;,&quot;${subclassname}&quot;)	}
//if(vars.get(&quot;barcode&quot;)!=&quot;&quot;){	avroRecord.put(&quot;barcode&quot;,${barcode})	}
if(vars.get(&quot;parentskuid&quot;)!=&quot;&quot;){	avroRecord.put(&quot;parent_sku_id&quot;,&quot;${parentskuid}&quot;)	}
//if(vars.get(&quot;planningsize&quot;)!=&quot;&quot;){	avroRecord.put(&quot;planning_size&quot;,&quot;${planningsize}&quot;)	}
if(vars.get(&quot;size&quot;)!=&quot;&quot;){	avroRecord.put(&quot;size&quot;,&quot;${size}&quot;)	}
if(vars.get(&quot;taxonomy&quot;)!=&quot;&quot;){	avroRecord.put(&quot;taxonomy&quot;,&quot;${taxonomy}&quot;)	}

String messageKey = &quot;PERFTEST_${rnd}&quot;;

log.info(&quot;${messageKey}&quot;);

ProducerRecord&lt;Object, Object&gt; record = new ProducerRecord&lt;&gt;(&quot;${kafka_topic_producer}&quot;, messageKey, avroRecord);

producer.send(record);





</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223Sampler>
