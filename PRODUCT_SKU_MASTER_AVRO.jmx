uot;],\&quot;default\&quot;:null},{\&quot;name\&quot;:\&quot;size\&quot;,\&quot;type\&quot;:[\&quot;null\&quot;,\&quot;string\&quot;],\&quot;default\&quot;:null},{\&quot;name\&quot;:\&quot;taxonomy\&quot;,\&quot;type\&quot;:[\&quot;null\&quot;,\&quot;string\&quot;],\&quot;default\&quot;:null}]}</stringProp>
